# ========================================
# CIREBON QRIS RUN 2026 - Environment Config
# ========================================

# ========== DATABASE ==========
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cirebon-run?retryWrites=true&w=majority

# ========== EMAIL (GMAIL SMTP) ==========
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-password-from-google
EMAIL_FROM_NAME="CIREBON QRIS RUN 2026"
EMAIL_FROM_ADDRESS=admin@cirebonqrisrun.com

# ========== CLOUDINARY ==========
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========== SERVER CONFIG ==========
PORT=5000
NODE_ENV=production
API_URL=https://your-backend-url.com
FRONTEND_URL=https://your-frontend-url.com

# ========== CORS ==========
CORS_ORIGIN=https://cirebonqrisrun.com,https://www.cirebonqrisrun.com

# ========== EVENT CONFIG ==========
EVENT_NAME="CIREBON QRIS RUN 2026"
EVENT_DATE=2026-08-16
EVENT_LOCATION="Grage Mall, Cirebon"

# ========== QRIS PRICES ==========
QRIS_5K=81000
QRIS_10K=131000

# ========== TIMEOUTS ==========
PAYMENT_TIMEOUT_MINUTES=15
REGISTRATION_FORM_TIMEOUT_MINUTES=10
AUTO_VERIFY_DELAY_SECONDS=3

# ========== ADMIN ==========
ADMIN_PASSWORD=your-secure-admin-password-min-12-chars

# ========== LOGGING ==========
LOG_LEVEL=info

# ========== FILE UPLOAD ==========
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf

# ========== PAYMENT VALIDATION ==========
AUTO_VERIFY_ENABLED=true
PAYMENT_TOLERANCE_PERCENTAGE=0

# ========== NOTIFICATION ==========
SEND_CONFIRMATION_EMAIL=true
SEND_VERIFICATION_EMAIL=true
SEND_REJECTION_EMAIL=true
SEND_REMINDER_EMAIL=true
REMINDER_DAYS_BEFORE=3
